# Copy to .env and edit before first launch.

# Unraid path. For local non-Unraid testing, use ./local-appdata
APPDATA_ROOT=/mnt/cache/appdata/icarus
STEAMCMD_ROOT=/mnt/user/appdata/steamcmd

# Network
GAME_PORT=17787
QUERY_PORT=27017

# Server identity
SERVER_NAME="SlurpNet Icarus"
SERVER_PASSWORD=
ADMIN_PASSWORD=
MAX_PLAYERS=8

# SteamCMD / container
GAME_ID=2089300
VALIDATE=
UID=99
GID=100

